SUPABASE_URL=http://127.0.0.1:54331
SUPABASE_SERVICE_KEY=your-service-role-key-here
API_SECRET=your-api-secret-here
OUTPUT_DIR=/tmp/mojo-stems
WORKER_ID=mac-worker-local
WORKER_CONCURRENCY=1
QUEUE_POLL_INTERVAL_SECONDS=0.5
JOB_HEARTBEAT_INTERVAL_SECONDS=15
JOB_HEARTBEAT_TIMEOUT_SECONDS=300
JOB_MAX_BACKOFF_SECONDS=300
DEMUCS_PYTHON=./venv/bin/python
DEMUCS_DEVICE=mps
DEMUCS_JOBS=4
# Separation quality. htdemucs_ft = fine-tuned 4-model ensemble (best quality,
# ~4x slower). Set DEMUCS_MODEL=htdemucs to trade quality for speed.
DEMUCS_MODEL=htdemucs_ft
# Shift trick: >1 averages multiple randomly-shifted passes for slightly
# cleaner output; each extra shift multiplies separation time.
DEMUCS_SHIFTS=1
# DEMUCS_SEGMENT=10
# Second-pass vocal refine with BS-Roformer (needs mac-server/venv-sep:
# python3.11 -m venv venv-sep && venv-sep/bin/pip install "audio-separator[cpu]").
# Falls back silently to Demucs vocals when disabled/missing/failing.
VOCAL_REFINE_ENABLED=true
# VOCAL_REFINE_MODEL=model_bs_roformer_ep_317_sdr_12.9755.ckpt
# Guitar refine with MelBand Roformer (becruily). Requires running
# `python3 register_custom_models.py` once (downloads model + patches venv-sep).
GUITAR_REFINE_ENABLED=true
# GUITAR_REFINE_MODEL=mel_band_roformer_guitar_becruily.ckpt
# SEPARATOR_MODEL_DIR=~/Library/Application Support/MrMojoRising/separator-models
WORKER_WARMUP_ENABLED=true
