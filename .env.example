# Turso (libSQL) — primary database.
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=

# Vercel Blob — stem audio storage. Get this from the Vercel dashboard.
BLOB_READ_WRITE_TOKEN=

# Mac server only.
# API_SECRET=dev-secret
# OUTPUT_DIR=/tmp/mojo-stems
# WORKER_ID=mac-worker
# WORKER_CONCURRENCY=1
